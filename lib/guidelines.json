{
  "required_clauses": {
    "nda": [
      "Definition of Confidential Information",
      "Obligations of Receiving Party",
      "Term and Duration",
      "Governing Law with Indian Jurisdiction"
    ],
    "service": [
      "Scope of Services",
      "Compensation with GST reference",
      "Term and Termination with notice period",
      "Governing Law with Indian Jurisdiction"
    ],
    "employment": [
      "Position and Duties",
      "Compensation with TDS reference",
      "Confidentiality clause",
      "Termination with notice period"
    ]
  },
  "mandatory_fields": {
    "gstin": {
      "pattern": "\\b\\d{2}[A-Z]{5}\\d{4}[A-Z]\\d[A-Z\\d]{2}\\b",
      "description": "15-character GST Identification Number",
      "applies_to": ["service"]
    },
    "pan": {
      "pattern": "\\b[A-Z]{5}\\d{4}[A-Z]\\b",
      "description": "10-character Permanent Account Number",
      "applies_to": ["employment"]
    },
    "jurisdiction": {
      "description": "Specific Indian city for court jurisdiction",
      "applies_to": ["nda", "service", "employment"]
    }
  },
  "deprecated_references": [
    {
      "find": "IT Act, 2000",
      "replace": "Digital India Act, 2026",
      "severity": "high"
    },
    {
      "find": "Information Technology Act",
      "replace": "Digital India Act, 2026",
      "severity": "high"
    }
  ],
  "compliance_notes": [
    "All monetary values must be in INR (₹) with applicable GST mentioned.",
    "Employment agreements must reference TDS under Income Tax Act.",
    "Service agreements must include GSTIN for both parties.",
    "Jurisdiction must specify a valid Indian city."
  ]
}
